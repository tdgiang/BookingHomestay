# Database
DATABASE_URL=postgresql://admin:password@localhost:5432/homestay

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=change-me-min-32-chars-random-secret
JWT_EXPIRATION=900
JWT_REFRESH_SECRET=change-me-another-min-32-chars-secret
JWT_REFRESH_EXPIRATION=604800

# Rate limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# CORS (comma-separated for multiple origins in production)
CORS_ORIGIN=http://localhost:3000

# Server
PORT=4000
